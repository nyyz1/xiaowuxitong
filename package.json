{
  "name": "school-affairs-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "pilot:school": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-school-pilot.ps1",
    "package:school": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-for-school.ps1",
    "setup:school": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-school-workstation.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:migrate:approval-roles": "node scripts/migrate-approval-role-model.mjs",
    "db:backfill:inspection-targets": "node scripts/backfill-inspection-target-types.mjs",
    "db:seed:approval-defaults": "node scripts/seed-approval-defaults.mjs",
    "db:seed:approval-pilot": "node scripts/seed-approval-pilot-config.mjs",
    "db:seed:approval-pilot:dry-run": "node scripts/seed-approval-pilot-config.mjs --dry-run",
    "db:seed:department-positions": "node scripts/seed-department-positions.mjs",
    "db:studio": "prisma studio",
    "smoke:pages": "node scripts/smoke-authenticated-pages.mjs",
    "smoke:positions": "node scripts/assert-position-permissions.mjs",
    "db:seed:demo": "node scripts/seed-demo-postgres.mjs",
    "db:seed:demo:dry-run": "node scripts/seed-demo-postgres.mjs --dry-run",
    "db:clear:demo": "node scripts/clear-demo-postgres.mjs",
    "db:clear:demo:dry-run": "node scripts/clear-demo-postgres.mjs --dry-run",
    "test:demo-db": "node scripts/simulate-school-affairs.mjs",
    "test:data-management": "node scripts/simulate-data-management.mjs"
  },
  "dependencies": {
    "@ant-design/nextjs-registry": "^1.3.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "antd": "^6.3.6",
    "bcryptjs": "^3.0.3",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.4.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
