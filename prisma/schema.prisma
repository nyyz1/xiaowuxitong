generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SYSTEM_ADMIN
  SCHOOL_LEADER
  DEPARTMENT_LEADER
  GRADE_MANAGER
  STUDENT_AFFAIRS_STAFF
  ACADEMIC_AFFAIRS_STAFF
  ADMIN_OFFICE_STAFF
  LOGISTICS_STAFF
  TEACHER
}

enum AccountType {
  STUDENT
  TEACHER
}

enum InspectionValueType {
  SCORE
  COUNT
  DEDUCTION
}

enum InspectionTargetType {
  STUDENT
  TEACHER
}

enum GradeStage {
  HIGH_ONE
  HIGH_TWO
  HIGH_THREE
  ALUMNI
}

enum ProfileFieldTargetType {
  TEACHER
  STUDENT
}

enum TeacherDepartmentIdentityType {
  FRONTLINE_TEACHER
  DEPARTMENT_LEADER
  GRADE_MANAGER
  STUDENT_AFFAIRS_STAFF
  ACADEMIC_AFFAIRS_STAFF
  LOGISTICS_STAFF
  GRADE_SUBJECT_LEADER
}

enum ApprovalRequestKind {
  MAINTENANCE
  PRINT
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalResponsibilityKind {
  LOGISTICS
  PRINT_TEACHING
  PRINT_GRADE_ADMIN
  PRINT_SCHOOL_ADMIN
  OTHER
}

enum PrintMaterialType {
  TEACHING
  GRADE_ADMIN
  SCHOOL_ADMIN
}

enum PrintMode {
  BLACK_WHITE
  COLOR
}

enum PaperSize {
  A4
  B5
  B3
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  displayName  String
  passwordHash String?
  accountType  AccountType @default(TEACHER)
  isSuperAdmin Boolean    @default(false)
  role         UserRole   @default(TEACHER)
  managedGradeId String?
  managedGrade Grade?     @relation("ManagedGradeUsers", fields: [managedGradeId], references: [id], onDelete: SetNull)
  teacherId    String?    @unique
  teacher      Teacher?   @relation("TeacherLoginUsers", fields: [teacherId], references: [id], onDelete: SetNull)
  studentId    String?    @unique
  student      Student?   @relation("StudentLoginUsers", fields: [studentId], references: [id], onDelete: SetNull)
  isActive     Boolean    @default(true)
  auditLogs    AuditLog[]
  inspections  InspectionRecord[]
  approvalResponsibilities ApprovalResponsibility[]
  submittedApprovalRequests ApprovalRequest[] @relation("ApprovalApplicantUsers")
  decidedApprovalRequests   ApprovalRequest[] @relation("ApprovalDecisionUsers")
  approvalLogs ApprovalLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([managedGradeId])
  @@index([teacherId])
  @@index([studentId])
  @@index([accountType, isActive])
  @@index([isSuperAdmin, isActive])
}

model AcademicYear {
  id        String   @id @default(cuid())
  name      String   @unique
  startDate DateTime?
  endDate   DateTime?
  isCurrent Boolean  @default(false)
  grades    Grade[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Grade {
  id             String       @id @default(cuid())
  name           String
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  stage          GradeStage?
  enrollmentYear Int?
  isVisibleInMain Boolean     @default(true)
  graduationYear Int?
  classes        Class[]
  managedUsers   User[]       @relation("ManagedGradeUsers")
  students       Student[]
  inspections    InspectionRecord[]
  approvalResponsibilities ApprovalResponsibility[]
  approvalRequests ApprovalRequest[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([academicYearId, name])
  @@unique([academicYearId, enrollmentYear])
  @@index([academicYearId, isVisibleInMain])
  @@index([enrollmentYear, isVisibleInMain])
  @@index([stage, isVisibleInMain])
  @@index([graduationYear])
}

model Class {
  id        String   @id @default(cuid())
  name      String
  gradeId   String
  grade     Grade    @relation(fields: [gradeId], references: [id], onDelete: Restrict)
  students  Student[]
  inspections InspectionRecord[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gradeId, name])
}

model Department {
  id                 String                     @id @default(cuid())
  name               String                     @unique
  teachers           Teacher[]
  teacherAssignments TeacherDepartmentAssignment[]
  positions          DepartmentPosition[]
  approvalResponsibilities ApprovalResponsibility[]
  approvalRequests ApprovalRequest[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
}

model DepartmentPosition {
  id                 String                        @id @default(cuid())
  departmentId       String
  department         Department                    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name               String
  identityType       TeacherDepartmentIdentityType @default(FRONTLINE_TEACHER)
  permissionTags     String[]                      @default([])
  sortOrder          Int                           @default(0)
  isActive           Boolean                       @default(true)
  teacherAssignments TeacherDepartmentAssignment[]
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt

  @@unique([departmentId, name])
  @@index([departmentId, sortOrder])
  @@index([identityType])
  @@index([isActive])
}

model Subject {
  id        String    @id @default(cuid())
  name      String    @unique
  teachers  Teacher[]
  approvalResponsibilities ApprovalResponsibility[]
  approvalRequests ApprovalRequest[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Teacher {
  id                  String                     @id @default(cuid())
  idCardNumber        String?                    @unique
  employeeNumber      String
  name                String
  gender              String?
  departmentId        String?
  department          Department?                @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  departmentAssignments TeacherDepartmentAssignment[]
  subjectId           String?
  subject             Subject?                   @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  duties              String[]                   @default([])
  profileData         Json                       @default("{}")
  phone               String?
  employmentStatus    String                     @default("ACTIVE")
  remarks             String?
  inspections         InspectionRecord[]
  loginUsers          User[]                     @relation("TeacherLoginUsers")
  approvalRequests    ApprovalRequest[]
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@index([idCardNumber])
  @@index([departmentId])
  @@index([subjectId])
}

model Student {
  id               String   @id @default(cuid())
  idCardNumber     String?  @unique
  studentNumber    String
  name             String
  gender           String?
  gradeId          String
  grade            Grade    @relation(fields: [gradeId], references: [id], onDelete: Restrict)
  classId          String?
  class            Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  enrollmentStatus String   @default("ACTIVE")
  isArchived       Boolean  @default(false)
  archivedAt       DateTime?
  profileData      Json     @default("{}")
  phone            String?
  guardianContact  String?
  remarks          String?
  loginUsers       User[]   @relation("StudentLoginUsers")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([idCardNumber])
  @@index([gradeId])
  @@index([classId])
  @@index([isArchived])
}

model TeacherDepartmentAssignment {
  teacherId    String
  departmentId String
  positionId   String?
  identityType TeacherDepartmentIdentityType @default(FRONTLINE_TEACHER)
  teacher      Teacher    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  position     DepartmentPosition? @relation(fields: [positionId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())

  @@id([teacherId, departmentId])
  @@index([departmentId])
  @@index([positionId])
  @@index([identityType])
}

model ProfileFieldDefinition {
  id         String                 @id @default(cuid())
  targetType ProfileFieldTargetType
  fieldKey   String?
  name       String
  sortOrder  Int                    @default(0)
  isActive   Boolean                @default(true)
  isDeleted  Boolean                @default(false)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@unique([targetType, name])
  @@unique([targetType, fieldKey])
  @@index([targetType, isActive, sortOrder])
  @@index([targetType, isDeleted, sortOrder])
}

model InspectionCategory {
  id        String           @id @default(cuid())
  name      String
  targetType InspectionTargetType @default(STUDENT)
  items     InspectionItem[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([targetType, name])
  @@index([targetType])
}

model InspectionItem {
  id          String              @id @default(cuid())
  name        String
  categoryId  String
  category    InspectionCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  valueType   InspectionValueType @default(SCORE)
  description String?
  isActive    Boolean             @default(true)
  records     InspectionRecord[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([categoryId, name])
}

model InspectionRecord {
  id               String         @id @default(cuid())
  inspectionDate   DateTime
  inspectionItemId String
  inspectionItem   InspectionItem @relation(fields: [inspectionItemId], references: [id], onDelete: Restrict)
  gradeId          String?
  grade            Grade?         @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  classId          String?
  class            Class?         @relation(fields: [classId], references: [id], onDelete: SetNull)
  teacherId        String?
  teacher          Teacher?       @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  recordedById     String?
  recordedBy       User?          @relation(fields: [recordedById], references: [id], onDelete: SetNull)
  value            Float
  remarks          String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([inspectionDate])
  @@index([inspectionItemId])
  @@index([gradeId])
  @@index([classId])
  @@index([teacherId])
}

model ApprovalType {
  id                 String                     @id @default(cuid())
  name               String                     @unique
  kind               ApprovalRequestKind        @default(OTHER)
  responsibilityKind ApprovalResponsibilityKind?
  description        String?
  isActive           Boolean                    @default(true)
  responsibilities   ApprovalResponsibility[]
  requests           ApprovalRequest[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([kind, isActive])
}

model ApprovalResponsibility {
  id            String                     @id @default(cuid())
  name          String
  kind          ApprovalResponsibilityKind
  approverId    String
  approver      User                       @relation(fields: [approverId], references: [id], onDelete: Cascade)
  requestTypeId String?
  requestType   ApprovalType?              @relation(fields: [requestTypeId], references: [id], onDelete: Cascade)
  gradeId       String?
  grade         Grade?                     @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  subjectId     String?
  subject       Subject?                   @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  departmentId  String?
  department    Department?                @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  isActive      Boolean                    @default(true)
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  @@index([kind, isActive])
  @@index([approverId])
  @@index([requestTypeId])
  @@index([gradeId])
  @@index([subjectId])
  @@index([departmentId])
}

model ApprovalRequest {
  id                 String              @id @default(cuid())
  typeId             String
  type               ApprovalType        @relation(fields: [typeId], references: [id], onDelete: Restrict)
  kind               ApprovalRequestKind
  applicantUserId    String
  applicantUser      User                @relation("ApprovalApplicantUsers", fields: [applicantUserId], references: [id], onDelete: Restrict)
  applicantTeacherId String?
  applicantTeacher   Teacher?            @relation(fields: [applicantTeacherId], references: [id], onDelete: SetNull)
  title              String
  content            String
  gradeId            String?
  grade              Grade?              @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  subjectId          String?
  subject            Subject?            @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  departmentId       String?
  department         Department?         @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  printMaterialType  PrintMaterialType?
  printMode          PrintMode?
  paperSize          PaperSize?
  printQuantity      Int?
  status             ApprovalStatus      @default(PENDING)
  currentApproverId  String?
  decidedById        String?
  decidedBy          User?               @relation("ApprovalDecisionUsers", fields: [decidedById], references: [id], onDelete: SetNull)
  decisionComment    String?
  decidedAt          DateTime?
  logs               ApprovalLog[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([typeId])
  @@index([kind, status])
  @@index([applicantUserId])
  @@index([applicantTeacherId])
  @@index([currentApproverId])
  @@index([decidedById])
  @@index([gradeId])
  @@index([subjectId])
  @@index([departmentId])
  @@index([createdAt])
}

model ApprovalLog {
  id        String          @id @default(cuid())
  requestId String
  request   ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?           @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  comment   String?
  createdAt DateTime        @default(now())

  @@index([requestId])
  @@index([actorId])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  targetType String
  targetId   String?
  summary    String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}
